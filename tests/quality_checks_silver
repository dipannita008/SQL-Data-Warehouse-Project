--QUALITY CHECKS FOR crm_prd_info

--Re-run the quality check queries from the bronze layer in the silver layer 
--to check the qaulity of data in silver layer.

--Check for nulls or duplicates in the primary key
--Expectation is no results

select prd_id,
count(*)
from silver.crm_prd_info
group by prd_id
having count(*)> 1 or prd_id is null

--Breaking Prd_key into cat_id and prd_key - First 5 chars are cat_id as it matches with the category table 
--and remaining chars will be the prd_key

select prd_id, 
prd_key,
replace(substring(prd_key, 1,5),'-','_') as cat_id,
substring(prd_key, 7, len(prd_key)) as prd_key
from silver.crm_prd_info

--Check for unwanted spaces in string values (prd_nm)
--Expectation is no results

select *
from silver.crm_prd_info
where prd_nm != TRIM(prd_nm)

--Check for nulls or negative nos.
--Expectation : No results

select prd_cost
from silver.crm_prd_info
where prd_cost<0 or prd_cost is null

--Check for Data Standardization & Consistency --replacing prd_line with valid values 'Mountain''Road' 'Other Sales'  'Touring'
select distinct 
prd_line
from silver.crm_prd_info   

--Check for Invalid Order Dates		  
									
select * 
from silver.crm_prd_info
where prd_end_dt < prd_start_dt

select prd_id, 
prd_key,
prd_nm, 
prd_cost, 
prd_line,
cast(prd_start_dt as date),
cast(lead(prd_start_dt) over(partition by prd_key order by prd_start_dt)-1 as date) as prd_end_dt
from silver.crm_prd_info

